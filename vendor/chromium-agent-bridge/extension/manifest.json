{
  "manifest_version": 3,
  "name": "Chromium Agent Bridge",
  "version": "0.1.0",
  "description": "Bridge AI agent commands to Chromium/Chrome tabs via localhost WebSocket.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "webNavigation",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>",
    "ws://127.0.0.1:8767/*",
    "http://127.0.0.1:8767/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "Chromium Agent Bridge"
  }
}